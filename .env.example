# Production (main branch)
VITE_CONVEX_URL=https://your-prod.convex.cloud
VITE_CONVEX_SITE_URL=https://your-prod.convex.site
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx

# Development (development branch) - use _DEV for GitHub repo variables
VITE_CONVEX_URL_DEV=https://your-dev.convex.cloud
VITE_CONVEX_SITE_URL_DEV=https://your-dev.convex.site
VITE_CLERK_PUBLISHABLE_KEY_DEV=pk_test_xxx
CLERK_SECRET_KEY_DEV=sk_test_xxx

# Optional
VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Cloudflare (CI only - add as GitHub secrets)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# CLERK_SECRET_KEY=sk_live_xxx (production Worker)
# CLERK_SECRET_KEY_DEV=sk_test_xxx (development Worker)
#
# For local dev, add CLERK_SECRET_KEY to .dev.vars
