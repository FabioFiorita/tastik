{
	"name": "tastik",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"dev": "vite dev --port 3000",
		"deploy": "bun run build && ./scripts/deploy-worker.sh",
		"deploy:dev": "bun run build && ./scripts/deploy-worker.sh .env.local development",
		"deploy:convex-and-merge": "./scripts/deploy-convex-and-merge.sh",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:once": "vitest run --passWithNoTests",
		"test:watch": "vitest --watch",
		"test:ui": "vitest --ui",
		"test:debug": "vitest --inspect-brk --no-file-parallelism",
		"test:coverage": "vitest run --coverage",
		"test:unit": "vitest run --project unit",
		"test:convex": "vitest run --project convex",
		"test:e2e": "playwright test",
		"format": "biome format",
		"lint": "biome lint",
		"check": "biome check",
		"check:write": "biome check --write --unsafe",
		"prepare": "husky"
	},
	"dependencies": {
