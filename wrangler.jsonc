{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "tastik",
	"compatibility_date": "2025-02-14",
	"compatibility_flags": ["nodejs_compat"],
	"main": "@tanstack/react-start/server-entry",
	"vars": {
		"VITE_CONVEX_URL": "",
		"VITE_CONVEX_SITE_URL": "",
		"VITE_CLERK_PUBLISHABLE_KEY": "",
		"VITE_SENTRY_DSN": ""
	},
	"env": {
		"development": {
			"name": "tastik-dev",
			"vars": {
				"VITE_CONVEX_URL": "",
				"VITE_CONVEX_SITE_URL": "",
				"VITE_CLERK_PUBLISHABLE_KEY": "",
				"VITE_SENTRY_DSN": ""
			}
		}
	}
}
